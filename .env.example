# Database
DATABASE_URL=postgresql://user:password@localhost:5432/foreclosure_flip_radar

# Redis
REDIS_URL=redis://localhost:6379

# BatchData API (property data)
BATCHDATA_API_KEY=
BATCHDATA_BASE_URL=https://api.batchdata.com/api/v1

# ATTOM API (property data)
ATTOM_API_KEY=
ATTOM_BASE_URL=https://api.gateway.attomdata.com

# NextAuth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# SMTP (email)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Google Maps
GOOGLE_MAPS_API_KEY=

# Application
LOG_LEVEL=info
NODE_ENV=development

# Feature flags
ENABLE_SKIP_TRACE=false
ENABLE_CONTACT_DATA=false
